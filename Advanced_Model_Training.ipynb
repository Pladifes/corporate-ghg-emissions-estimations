    "    path_results = 'results/restricted_features/'\n",
    "    path_plot = path_results +'plot/'\n",
    "\n",
    "\n",
    "# Results containers\n",
    "summary_final=[]\n",
    "Summary_Final_train = []\n",
    "summary_metrics_detailed = pd.DataFrame()\n",
    "estimated_scopes = []"
   ]
